generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums — keep in sync with packages/shared/src/enums.ts (the API validates
// requests against the shared Zod schemas; these are the DB-level mirror).
// ─────────────────────────────────────────────────────────────────────────────

enum Role {
  USER
  ADMIN
}

enum WorkMode {
  REMOTE
  HYBRID
  ONSITE
}

enum VisaSponsorship {
  REQUIRED
  NOT_REQUIRED
  OPEN_TO_EITHER
}

enum CompanySize {
  SEED_STARTUP
  EARLY_STAGE
  GROWTH
  MID_SIZE
  ENTERPRISE
}

enum ApplicationStatus {
  SAVED
  APPLIED
  OA
  INTERVIEW
  OFFER
  REJECTED
  ACCEPTED
  WITHDRAWN
}

// Keep in sync with packages/shared/src/ats.ts AtsProviderSchema
enum AtsProvider {
  GREENHOUSE
  LEVER
  ASHBY
  WORKDAY
  SMARTRECRUITERS
  RECRUITEE
  TEAMTAILOR
  WORKABLE
  BREEZY
  KEKA
  DARWINBOX
  ZOHO_RECRUIT
  FRESHTEAM
  OTHER
  UNKNOWN
}

enum HiringTrend {
  GROWING
  STABLE
  DECLINING
  INSUFFICIENT_DATA // < 14 days of monitoring history
}

enum JobStatus {
  ACTIVE
  REMOVED // disappeared from the source on a later crawl
  EXPIRED // source marked it closed
}

// Monitoring cadence: HOT = companies the user follows/applied to, WARM = default
// for monitored companies, COLD = long-tail. Intervals live in code (ingest.service).
enum CrawlTier {
  HOT
  WARM
  COLD
}

// Discovery lifecycle: Discover → Verify Website → Find Career Page → Detect ATS
// → MONITORED (jobs flowing). UNRESOLVABLE = probing exhausted, retried monthly.
enum DiscoveryStage {
  DISCOVERED
  WEBSITE_VERIFIED
  CAREER_PAGE_FOUND
  MONITORED
  UNRESOLVABLE
}

enum CrawlStatus {
  RUNNING
  SUCCEEDED
  FAILED
  PARTIAL // finished but some pages/endpoints errored
}

enum NotificationType {
  NEW_MATCHES
  DAILY_DIGEST
  WEEKLY_REPORT
  SYSTEM
}

// ─────────────────────────────────────────────────────────────────────────────
// Identity & preferences
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String? // null for OAuth-only accounts
  name            String?
  role            Role      @default(USER)
  emailVerifiedAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  preference    UserPreference?
  refreshTokens RefreshToken[]
  resumes       Resume[]
  matches       JobMatch[]
  applications  Application[]
  notifications Notification[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique // store a hash, never the raw token
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model UserPreference {
  id               String           @id @default(cuid())
  userId           String           @unique
  preferredRoles   String[]         @default([])
  techStack        String[]         @default([])
  minSalary        Int?
  salaryCurrency   String? // ISO 4217, e.g. "INR", "USD"
  countries        String[]         @default([])
  cities           String[]         @default([])
  workModes        WorkMode[]       @default([])
  noticePeriodDays Int?
  visaSponsorship  VisaSponsorship?
  companySizes     CompanySize[]    @default([])
  industries       String[]         @default([])
  updatedAt        DateTime         @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// Resumes — a Resume is the logical document ("Backend resume"), each upload
// creates a new immutable ResumeVersion. Parsing output and embeddings hang
// off the version, so history/comparison across versions comes for free.
// ─────────────────────────────────────────────────────────────────────────────

model Resume {
  id        String   @id @default(cuid())
  userId    String
  title     String   @default("My Resume")
  isPrimary Boolean  @default(false) // the one used for matching by default
  createdAt DateTime @default(now())

  user     User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  versions ResumeVersion[]

  @@index([userId])
  @@map("resumes")
}

model ResumeVersion {
  id            String   @id @default(cuid())
  resumeId      String
  versionNumber Int
  fileKey       String // object key in S3/MinIO — never store the file in the DB
  parsedJson    Json? // structured extraction: experience, education, projects, ...
  atsScore      Int? // 0–100 from checkAts() on the raw text layer
  atsVerdict    String? // SAFE | RISKY | UNREADABLE — what a real ATS would see
  // The user's corrections to the AI parse. Once set, this — not parsedJson —
  // is the profile matching runs against.
  confirmedProfile Json?
  // Skills the user added that are NOT in the resume text. Valid profile data,
  // but CareerOS must never claim the submitted PDF contains them.
  manuallyAddedSkills String[] @default([])
  // [{ skill, source: RESUME_EXTRACTED | MANUALLY_ADDED }] — the same judgement
  // as manuallyAddedSkills, but stated per-skill and positively rather than as
  // an absence, so every surface can cite where a skill came from.
  skillProvenance Json?
  // Matching uses the newest ACTIVATED version, never merely the newest upload.
  // Without this an unreviewed parse starts scoring jobs the instant the file
  // lands, which is exactly what the confirmation step exists to prevent.
  activatedAt   DateTime?
  // Reconciliation runs in the background (minutes of paced LLM calls), so its
  // before/after report is stored rather than returned from the HTTP request.
  reconciledAt    DateTime?
  reconcileReport Json?
  createdAt     DateTime @default(now())

  resume    Resume           @relation(fields: [resumeId], references: [id], onDelete: Cascade)
  skills    ResumeSkill[]
  embedding ResumeEmbedding?
  matches   JobMatch[]

  @@unique([resumeId, versionNumber])
  @@map("resume_versions")
}

model ResumeEmbedding {
  id              String                      @id @default(cuid())
  resumeVersionId String                      @unique
  model           String // embedding model id, e.g. "text-embedding-3-small"
  vector          Unsupported("vector(1536)")
  createdAt       DateTime                    @default(now())

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  @@map("resume_embeddings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Skills — canonical vocabulary. Skill-gap analysis = JobSkill minus
// ResumeSkill via joins, not string matching.
// ─────────────────────────────────────────────────────────────────────────────

model Skill {
  id       String  @id @default(cuid())
  name     String  @unique // normalized lowercase, e.g. "react", "postgresql"
  category String? // "language" | "framework" | "database" | "cloud" | ...

  resumeSkills ResumeSkill[]
  jobSkills    JobSkill[]

  @@map("skills")
}

model ResumeSkill {
  resumeVersionId String
  skillId         String
  yearsOfUse      Float?

  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)
  skill         Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([resumeVersionId, skillId])
  @@map("resume_skills")
}

model JobSkill {
  jobId    String
  skillId  String
  required Boolean @default(true) // required vs nice-to-have

  job   Job   @relation(fields: [jobId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([jobId, skillId])
  @@map("job_skills")
}

// ─────────────────────────────────────────────────────────────────────────────
// Companies & jobs
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id            String       @id @default(cuid())
  name          String
  website       String?      @unique
  careerPageUrl String?
  atsProvider   AtsProvider  @default(UNKNOWN)
  atsIdentifier String? // e.g. Greenhouse board token, Lever site slug
  crawlTier     CrawlTier @default(WARM)
  nextCrawlAt   DateTime  @default(now()) // due when <= now; bumped per-tier after each sync

  // ── Discovery pipeline (Phase B) ──
  discoveryStage    DiscoveryStage @default(DISCOVERED)
  discoverySource   String? // "seed" | "remoteok" | "yc" | "manual" | ...
  // Confidence 0-100 from confidenceSignals — how sure we are this is a real,
  // monitorable employer. Recomputed on every discovery/crawl event.
  confidence        Float          @default(0)
  confidenceSignals Json? // { websiteVerified, careerPageFound, atsDetected, jobsExtracted, monitoringHealthy }
  lastProbedAt      DateTime? // discovery prober bookkeeping — due again after cooldown

  country       String?
  city          String? // for city-based discovery (Indore/Pune/Bangalore...)
  teamSize      Int? // from directory metadata (e.g. YC dataset)
  industry      String?
  size          CompanySize?
  logoUrl            String?
  linkedinUrl        String?
  githubOrg          String?
  engineeringBlogUrl String?
  description        String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  jobs         Job[]
  crawlRuns    CrawlRun[]
  intelligence CompanyIntelligence?

  // One company per ATS board — prevents two rows crawling the same source.
  @@unique([atsProvider, atsIdentifier])
  @@index([name])
  @@index([nextCrawlAt]) // the "due now" scheduler query
  @@index([discoveryStage, lastProbedAt]) // the discovery prober's due query
  @@map("companies")
}

model Job {
  id          String    @id @default(cuid())
  companyId   String
  externalId  String // stable id from the source (ATS job id or canonical URL)
  title       String
  description String
  location    String?
  country     String?
  workMode    WorkMode?
  salaryMin   Int?
  salaryMax   Int?
  currency    String?
  seniority   String? // free-form until Phase 5 normalizes it
  url         String
  postedAt    DateTime?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now()) // crawler bumps this every run it still sees the job
  status      JobStatus @default(ACTIVE)
  raw         Json? // original source payload, for reprocessing without recrawling
  // GENERATED ALWAYS AS to_tsvector(title+description) STORED — created in a
  // hand-edited migration; @default(dbgenerated()) tells Prisma a db-side
  // expression owns this column so its diff engine leaves it alone.
  search      Unsupported("tsvector")? @default(dbgenerated())

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  skills       JobSkill[]
  embedding    JobEmbedding?
  matches      JobMatch[]
  applications Application[]
  classifications JobClassification[]

  // Dedupe guarantee: a recrawl updates the existing row instead of inserting.
  @@unique([companyId, externalId])
  @@index([search], type: Gin)
  @@index([status, firstSeenAt])
  @@index([title])
  @@index([country, workMode])
  @@map("jobs")
}

model JobEmbedding {
  id        String                      @id @default(cuid())
  jobId     String                      @unique
  model     String
  vector    Unsupported("vector(1536)")
  createdAt DateTime                    @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@map("job_embeddings")
}

// ─────────────────────────────────────────────────────────────────────────────
// Matching & tracking
// ─────────────────────────────────────────────────────────────────────────────

model JobMatch {
  id              String    @id @default(cuid())
  userId          String
  jobId           String
  resumeVersionId String // which resume version produced these scores
  overallScore    Float // 0–100
  technicalScore  Float
  experienceScore Float
  missingSkills   String[]  @default([])
  reasoning       String? // LLM explanation shown in the dashboard

  // ── Opportunity Score (Phase C) ──
  opportunityScore Float? // 0-100 combined from scoreBreakdown modules
  scoreBreakdown   Json? // [{module, score, weight, reason}] — explainability
  contentHash      String? // job title+salary hash at scoring time — re-notify trigger

  // ── Canonical decision (2026-07-10) ──
  // The ONE verdict. Dashboard, Telegram, 8 AM brief, 2 PM digest and the job
  // page all read this column. No consumer may re-derive APPLY/CONSIDER from
  // opportunityScore: that is how a marketing role reached "Apply today" while
  // the notification path would have blocked it.
  verdict         String? // APPLY | CONSIDER | SKIP | NEEDS_REVIEW
  verdictReason   String?
  verdictCode     String? // TARGET_ROLE_ELIGIBLE | DEVELOPMENT_WRONG_SPECIALIZATION | ...
  /** Legacy blended number; prefer the three below. */
  roleRelevance   Int?
  // Four questions, four answers. Blending them is what recommended a
  // digital-marketing role at 65% resume fit, and printed "100% relevant"
  // beside a React Native job.
  //   developmentConfidence — is hands-on software development core here?
  //   targetRoleFit         — is this one of the role families I search for?
  //   specializationFit     — is the JD's required stack my stack?
  //   overallScore          — does my resume satisfy this specific JD?
  developmentConfidence Int?
  targetRoleFit         Int?
  specializationFit     Int?
  /** What the user should DO: APPLY_NOW | WORTH_APPLYING | REVIEW_FIRST | LOW_PRIORITY | SKIP */
  actionRecommendation  String?
  decisionVersion Int?
  decidedAt       DateTime?

  notifiedAt DateTime? // notification memory: set when the user was told
  createdAt  DateTime  @default(now())

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  job           Job           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  resumeVersion ResumeVersion @relation(fields: [resumeVersionId], references: [id], onDelete: Cascade)

  // One match per (user, job, resume version). A new resume produces new rows
  // rather than overwriting the old ones, so "which resume version got
  // interviews" stays answerable. Reads must filter to the ACTIVE version;
  // without that filter this constraint silently double-counts.
  @@unique([userId, jobId, resumeVersionId])
  @@index([userId, resumeVersionId])
  @@index([userId, overallScore])
  @@map("job_matches")
}

model Application {
  id        String            @id @default(cuid())
  userId    String
  jobId     String
  status    ApplicationStatus @default(SAVED)
  notes     String?
  appliedAt DateTime?
  // Outcome-analytics foundations ("which resume version gets interviews",
  // "which source converts") — recorded from the first application onward.
  resumeVersionId String?
  source          String? // "careeros-match" | "referral" | "manual" | board name
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  user   User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  job    Job                @relation(fields: [jobId], references: [id], onDelete: Cascade)
  events ApplicationEvent[]

  @@unique([userId, jobId])
  @@index([userId, status])
  @@map("applications")
}

// Append-only status timeline — the tracker's history view reads this directly.
model ApplicationEvent {
  id            String             @id @default(cuid())
  applicationId String
  fromStatus    ApplicationStatus?
  toStatus      ApplicationStatus
  note          String?
  createdAt     DateTime           @default(now())

  application Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId, createdAt])
  @@map("application_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Notifications & crawler observability
// ─────────────────────────────────────────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  payload   Json // e.g. { matchIds: [...] } — rendered by the frontend
  readAt    DateTime?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────────
// Company Intelligence (Phase B.5) — derived per-company profile. Most fields
// come from OUR OWN job corpus (LLM extraction + SQL aggregates), not from
// external scraping — free to compute and refreshed weekly.
// ─────────────────────────────────────────────────────────────────────────────

/**
 * What a job IS — objective, cached, and versioned. Never user-specific: this
 * table says "Android engineering, coding PRIMARY, minimum 2 years", never
 * "reject for Suyash". Personal fit is derived per user at read time.
 *
 * Rows are kept per classifierVersion so a prompt change can be audited and
 * selectively recomputed rather than silently overwriting history.
 */
model JobClassification {
  id                String @id @default(cuid())
  jobId             String
  classifierVersion Int

  primaryFunction       String // SOFTWARE_ENGINEERING | MARKETING_GROWTH | ...
  roleFamily            String // FULL_STACK | NATIVE_ANDROID | ...
  specializations       String[] @default([])
  codingIntensity       String // PRIMARY | SUBSTANTIAL | OCCASIONAL | INCIDENTAL | NONE
  /** 0–100: how certain that BUILDING SOFTWARE is the core of this job. */
  developmentConfidence Int
  seniority             String // INTERN | JUNIOR | MID | SENIOR | LEAD | STAFF | PRINCIPAL | UNKNOWN
  minimumYears          Int?
  maximumYears          Int?

  requiredSkills        String[] @default([])
  preferredSkills       String[] @default([])
  responsibilities      String[] @default([])
  developmentEvidence   String[] @default([])
  nonDevelopmentEvidence String[] @default([])
  classificationReason  String

  classifiedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([jobId, classifierVersion])
  @@index([classifierVersion])
  @@index([primaryFunction, roleFamily])
  @@map("job_classifications")
}

model CompanyIntelligence {
  id        String @id @default(cuid())
  companyId String @unique

  // LLM-extracted from this company's job descriptions
  techStack        String[] @default([]) // normalized lowercase, matches skills vocabulary
  remoteFriendly   Boolean?
  visaMentioned    Boolean? // job texts mention visa sponsorship
  hiresJuniors     Boolean? // roles at <= 2y experience seen
  avgExperienceReq Float? // average minimum years asked across jobs
  roleMix          Json? // { backend: n, frontend: n, fullstack: n, ai: n, devops: n, other: n }

  // SQL aggregates from our own data
  salaryMinMedian Int? // median of posted salaryMin (where disclosed)
  salaryMaxMedian Int?
  activeJobs      Int      @default(0)
  hiringVelocity  Json? // { months: [{month, newJobs}], changePct }
  hiringTrend     HiringTrend @default(INSUFFICIENT_DATA)

  derivedAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@map("company_intelligence")
}

// One row per crawl attempt per company — the admin panel's data source.
model CrawlRun {
  id          String      @id @default(cuid())
  companyId   String?
  source      String // "greenhouse" | "lever" | "scraper:playwright" | ...
  status      CrawlStatus @default(RUNNING)
  startedAt   DateTime    @default(now())
  finishedAt  DateTime?
  jobsFound   Int         @default(0)
  jobsNew     Int         @default(0)
  jobsRemoved Int         @default(0)
  error       String?

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([companyId, startedAt])
  @@index([status, startedAt])
  @@map("crawl_runs")
}

// ─────────────────────────────────────────────────────────────────────────────
// AI usage accounting — one row per provider call (or batched embed call).
// costUsd is an estimate from a static price table; the vendor invoice is
// authoritative. Feeds GET /ai/usage so running costs are visible, not guessed.

enum AiCallKind {
  EMBED
  GENERATE
}

model AiUsage {
  id           String     @id @default(cuid())
  kind         AiCallKind
  provider     String // "gemini" | "openai" | ...
  model        String
  items        Int        @default(1) // texts embedded, or 1 per generate call
  inputTokens  Int?
  outputTokens Int?
  costUsd      Decimal?   @db.Decimal(10, 6)
  ok           Boolean
  errorCode    String? // "http_429" | "quota_circuit_open" | ...
  latencyMs    Int

  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([kind, createdAt])
  @@map("ai_usage")
}
